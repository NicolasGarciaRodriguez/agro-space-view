PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Local: MongoDB sin autenticación (mongod en 127.0.0.1:27017)
MONGODB_URI=mongodb://127.0.0.1:27017/agrospace

# Producción (MongoDB Atlas): usuario, contraseña y cluster en la URI
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/agrospace?retryWrites=true&w=majority

JWT_SECRET=cambia-este-secreto-en-local
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
